# ═════════════════════════════════════════════════════════════
# Configuración de Violet Uploader
# ═════════════════════════════════════════════════════════════
#
# Copia este archivo a .env y complétalo con tus valores.
# También puedes configurar los webhooks desde la app en
# Configuración → Webhooks de Discord.
#
# ═════════════════════════════════════════════════════════════

# ── CARPETA DE GRABACIONES ─────────────────────────────────
# Ruta donde se guardan las grabaciones de OBS.
# Esta variable no se usa en violet_uploader.py, pero se
# mantiene por compatibilidad con otros módulos.
OBS_FOLDER=''

# ── WEBHOOKS DE DISCORD (5 slots) ──────────────────────────────
#
# Puedes configurar hasta 5 webhooks. Cada uno necesita:
#   - DISCORD_WEBHOOK_N      = URL del webhook
#   - DISCORD_WEBHOOK_NAME_N  = Nombre del canal (ej: "Mis Videos")
#
# Donde N es 0, 1, 2, 3 o 4.
#
# Ejemplo:
#   DISCORD_WEBHOOK_0=https://discord.com/api/webhooks/123456789/abcdefghij
#   DISCORD_WEBHOOK_NAME_0=Mi Canal
#
DISCORD_WEBHOOK_0=
DISCORD_WEBHOOK_NAME_0=

DISCORD_WEBHOOK_1=
DISCORD_WEBHOOK_NAME_1=

DISCORD_WEBHOOK_2=
DISCORD_WEBHOOK_NAME_2=

DISCORD_WEBHOOK_3=
DISCORD_WEBHOOK_NAME_3=

DISCORD_WEBHOOK_4=
DISCORD_WEBHOOK_NAME_4=

# ── WEBHOOK SELECCIONADO ─────────────────────────────────
# Índice (0-4) del webhook seleccionado por defecto.
# Se muestra en el desplegable al iniciar la app.
DISCORD_WEBHOOK_SELECTED='0'